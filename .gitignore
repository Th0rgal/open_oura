.DS_Store
.venv/
__pycache__/
*.py[cod]

# Rust build artifacts
/target/

# Local SQLite databases may contain device serials and personal ring data.
*.db
*.db-journal
*.sqlite

# Local BLE captures may include serials, MAC-derived identifiers, or auth data.
captures/
*.pcap
*.pcapng
*.btsnoop
*.log

# Reverse-engineering work products are large and may include proprietary app code.
reverse/android/*.xapk
reverse/android/*.apk
reverse/android/*page.html
reverse/android/xapk/
reverse/android/apktool-main/
reverse/android/jadx-main/

# Auth keys generated by `oura pair`.
*.key

# Personal data exports and local working notes (kept off the repo).
*.csv
notes/

# Proprietary Oura ML model artifacts — local only, not for publication without
# permission. (notes/ already covers notes/models/; this also blocks any model
# artifact placed elsewhere, in any on-device runtime format.)
*.pt
*.pth
*.ptl
*.pte
*.onnx
*.mlmodel
*.mlpackage

# Local-only working material kept off the repo (research tooling, scratch
# scripts, working docs). Single home for anything not meant for publication.
/local/

# Playwright MCP artifacts
.playwright-mcp/

# mitmproxy-captured tokens (local only)
tools/oura_tokens.txt

# Local screenshot artifacts (Playwright, dashboard previews)
/*.png

# Personal profile (age/weight/etc) — not from the ring, local only
profile.json

# On-ring feature modes snapshot (local device state)
feature_modes.json

# iOS build outputs — all regenerated by the build scripts (build-rust.sh / xcodebuild)
apps/ios/OuraCore.xcframework/
apps/**/build/
apps/**/build-torch/
# bundled libtorch for the on-device model spike (huge; fetched by build_libtorch_ios.sh)
apps/ios/spike/libtorch*/
*.xcuserstate

